# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=boilerplate
APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/boilerplate?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=300

# ── NATS (opsional — aktifkan untuk production event bus) ─────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=APP_EVENTS
USE_NATS=false

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=ganti-dengan-string-acak-minimal-32-karakter-yang-aman
JWT_EXPIRY_HOURS=24
JWT_ISSUER=boilerplate-api
JWT_REFRESH_MULTIPLIER=7

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9090

# ── HTTP Server ───────────────────────────────────────────────────────────────
HTTP_READ_TIMEOUT_SECONDS=15
HTTP_WRITE_TIMEOUT_SECONDS=15
HTTP_IDLE_TIMEOUT_SECONDS=60
HTTP_MIDDLEWARE_TIMEOUT_SECONDS=30
HTTP_MAX_PAGE_SIZE=1000

# ── Tenant & Org Scope Hierarchy ─────────────────────────────────────────────
# TENANT_MODE: "single" (self-hosted / dedicated) | "multi" (SaaS / shared)
TENANT_MODE=single

# Mode "single": isi semua level yang dipakai deployment ini.
# Mode "multi":  hapus / komentari semua di bawah — nilai datang dari JWT claims.

# L1 — Tenant (wajib jika mode=single)
TENANT_ID=00000000-0000-0000-0000-000000000001

# L2 — Company / Legal entity (wajib jika mode=single)
COMPANY_ID=00000000-0000-0000-0000-000000000002

# L3 — Branch / Cabang operasional (opsional)
# BRANCH_ID=00000000-0000-0000-0000-000000000003

# L4 — Warehouse / Gudang (opsional — lebih baik kirim via request body)
# WAREHOUSE_ID=00000000-0000-0000-0000-000000000004
